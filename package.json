{
  "name": "saju-concierge",
  "version": "0.1.0",
  "private": true,
  "description": "Saju Concierge — a Korean fortune (saju/manseryeok) MCP server: Four Pillars chart, today's energy, compatibility, personality type, yearly flow, name reading. Agentic Player 10.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint:naming": "tsx scripts/lint-naming.ts",
    "build": "npm run lint:naming && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "inspect": "npx -y @modelcontextprotocol/inspector",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fullstackfamily/manseryeok": "^1.0.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
